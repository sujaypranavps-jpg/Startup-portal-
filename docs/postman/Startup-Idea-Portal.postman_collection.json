{
  "info": {
    "name": "Startup Idea Portal API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Demo Startup\",\n  \"email\": \"demo@startup.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"startup\"\n}"
        }
      }
    },
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"startup1@portal.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "List Ideas",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": "{{baseUrl}}/ideas"
      }
    },
    {
      "name": "Create Investment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/investments/idea/{{ideaId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 200000,\n  \"partnershipType\": \"equity\",\n  \"note\": \"Interested in seed round\"\n}"
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "ideaId", "value": "" }
  ]
}
